PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
STORAGE_DIR=./storage

# Optional: lets the demo feedback form create GitHub issues.
GITHUB_OWNER=your-github-owner
GITHUB_REPO=ai-feedback-loop-demo
GITHUB_TOKEN=github-app-or-fine-grained-token

# GitHub Actions secrets, not local env in normal use:
# AI_PROXY_KEY=...
# AI_RESPONSES_ENDPOINT=https://your-proxy.example.com/v1/responses
